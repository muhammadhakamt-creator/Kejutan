<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>DroidTrack V2 - Cloud Sync</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #020617; color: #f8fafc; font-family: sans-serif; overflow-x: hidden; }
        .admin-panel { display: none; }
        .target-panel { display: none; }
        #mapFrame { width: 100%; height: 400px; border-radius: 1.5rem; margin-top: 1rem; border: 2px solid #1e293b; background: #0f172a; }
        .neon-border { box-shadow: 0 0 15px rgba(6, 182, 212, 0.3); }
    </style>
</head>
<body class="p-4 md:p-8">

    <div class="max-w-md mx-auto">
        <header class="flex items-center justify-between mb-8">
            <h1 class="text-2xl font-black text-cyan-500 tracking-tighter italic">DROID<span class="text-white">TRACK</span></h1>
            <div id="statusBadge" class="px-3 py-1 rounded-full text-[10px] font-bold bg-slate-800 text-slate-400">IDLE</div>
        </header>
        
        <div id="adminView" class="admin-panel space-y-4">
            <div class="bg-slate-900 p-5 rounded-2xl border border-slate-800 neon-border">
                <div class="flex justify-between items-start mb-4">
                    <div>
                        <h2 class="text-emerald-400 font-bold uppercase text-[10px] tracking-widest">Target Terdeteksi</h2>
                        <p id="targetIdDisp" class="text-lg font-bold">User_001</p>
                    </div>
                    <div class="text-right">
                        <p class="text-[10px] text-slate-500 uppercase">Update Terakhir</p>
                        <p id="lastSeen" class="text-xs font-mono">-</p>
                    </div>
                </div>
                
                <div class="space-y-2 py-3 border-y border-slate-800/50">
                    <p class="text-xs text-slate-400 flex items-start">
                        <span class="mr-2">📍</span>
                        <span id="addr">Mencari alamat presisi...</span>
                    </p>
                </div>

                <div class="grid grid-cols-2 gap-2 mt-4">
                    <div class="bg-black/40 p-2 rounded-lg">
                        <span class="text-[9px] text-slate-500 block">LATITUDE</span>
                        <span id="latVal" class="text-xs font-mono text-cyan-400">-</span>
                    </div>
                    <div class="bg-black/40 p-2 rounded-lg">
                        <span class="text-[9px] text-slate-500 block">LONGITUDE</span>
                        <span id="lngVal" class="text-xs font-mono text-cyan-400">-</span>
                    </div>
                </div>
            </div>
            
            <iframe id="mapFrame" src="about:blank"></iframe>
            <p class="text-[10px] text-center text-slate-600 uppercase tracking-widest">Sistem enkripsi end-to-end aktif</p>
        </div>

        <div id="targetView" class="target-panel space-y-6 text-center py-6">
            <div class="bg-slate-900 p-8 rounded-[2.5rem] border border-slate-800 shadow-2xl">
                <div class="w-20 h-20 bg-gradient-to-tr from-cyan-600 to-blue-500 rounded-3xl mx-auto mb-6 flex items-center justify-center rotate-12 shadow-lg shadow-cyan-500/20">
                    <svg class="w-10 h-10 text-white -rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                </div>
                <h2 class="text-2xl font-bold mb-3 text-white">Bagi Lokasi Anda</h2>
                <p class="text-slate-400 text-sm leading-relaxed mb-8">Tekan tombol di bawah untuk mengaktifkan pemancaran koordinat GPS ke server pemantauan.</p>
                
                <button id="btnLacak" onclick="mulaiKirimLokasi()" class="w-full bg-cyan-500 hover:bg-cyan-400 text-slate-950 font-black py-4 rounded-2xl shadow-xl active:scale-95 transition-all uppercase tracking-tighter">
                    AKTIFKAN TRANSMISI
                </button>
                
                <p id="transmittingText" class="hidden mt-6 text-emerald-400 text-[10px] font-bold animate-pulse tracking-[0.2em]">MEMANCARKAN SINYAL GPS...</p>
            </div>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getFirestore, doc, setDoc, onSnapshot } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

        // !!! GANTI DENGAN CONFIG FIREBASE ANDA !!!
        const firebaseConfig = {
            apiKey: "MASUKKAN_API_KEY_DI_SINI",
            authDomain: "PROJECT_ANDA.firebaseapp.com",
            projectId: "PROJECT_ANDA",
            storageBucket: "PROJECT_ANDA.appspot.com",
            messagingSenderId: "123456789",
            appId: "1:123456789:web:abcdef"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const trackerId = "user_primary_01"; 

        const urlParams = new URLSearchParams(window.location.search);
        const role = urlParams.get('role');

        if (role === 'admin') {
            document.getElementById('adminView').style.display = 'block';
            document.getElementById('statusBadge').innerText = "MONITORING MODE";
            document.getElementById('statusBadge').classList.replace('text-slate-400', 'text-emerald-400');
            mulaiMonitoring();
        } else {
            document.getElementById('targetView').style.display = 'block';
            document.getElementById('statusBadge').innerText = "TARGET MODE";
        }

        // FUNGSI TARGET: Kirim lokasi ke Firebase
        window.mulaiKirimLokasi = function() {
            if (!navigator.geolocation) return alert("Browser tidak mendukung GPS!");
            
            document.getElementById('btnLacak').disabled = true;
            document.getElementById('btnLacak').innerText = "TRANSMISI AKTIF";
            document.getElementById('btnLacak').classList.replace('bg-cyan-500', 'bg-slate-800');
            document.getElementById('btnLacak').classList.add('text-emerald-400');
            document.getElementById('transmittingText').classList.remove('hidden');

            navigator.geolocation.watchPosition((pos) => {
                setDoc(doc(db, "track_data", trackerId), {
                    lat: pos.coords.latitude,
                    lng: pos.coords.longitude,
                    time: Date.now(),
                    active: true
                });
            }, (err) => alert("Harap aktifkan GPS & Beri Izin!"), { enableHighAccuracy: true });
        };

        // FUNGSI ADMIN: Baca lokasi dari Firebase
        function mulaiMonitoring() {
            onSnapshot(doc(db, "track_data", trackerId), (snapshot) => {
                if (snapshot.exists()) {
                    const data = snapshot.data();
                    document.getElementById('lastSeen').innerText = new Date(data.time).toLocaleTimeString();
                    document.getElementById('latVal').innerText = data.lat.toFixed(6);
                    document.getElementById('lngVal').innerText = data.lng.toFixed(6);
                    
                    // Update Peta Google Maps
                    const lat = data.lat;
                    const lng = data.lng;
                    document.getElementById('mapFrame').src = `https://maps.google.com/maps?q=${lat},${lng}&z=16&output=embed`;
                    
                    // Alamat (Reverse Geocode Gratis)
                    fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`)
                        .then(r => r.json()).then(d => {
                            document.getElementById('addr').innerText = d.display_name;
                        }).catch(() => {
                            document.getElementById('addr').innerText = "Koordinat terkunci, gagal memuat nama jalan.";
                        });
                }
            });
        }
    </script>
</body>
</html>


